{
	"compilerOptions": {
		"target": "es2015",
		"module": "node16",
		"moduleResolution": "node16", // required for vitest's type testing to not crash horribly
		// TS6 and onwards default `types` to including nothing by default
		// (which causes annoying errors for contributors using TSGo)
		"types": ["@types/node"],
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"stripInternal": true
	},
	"files": ["index.ts"],
	"exclude": ["test"]
}
