{
	"compilerOptions": {
		"target": "ES2020",
		"module": "Node16",
		// TS6/7 default types to including nothing by default;
		// this prevents spurious errors for people using TSGo/etc.
		"types": ["@types/node"],
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"stripInternal": true
	},
	"files": ["index.ts"],
	"exclude": ["test"]
}
